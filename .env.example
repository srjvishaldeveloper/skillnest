# SkillNest LMS environment template. Copy to .env and fill in real values.

# ===== Core =====
DATABASE_URL=postgresql://user:password@localhost:5432/skillnest
# Session signing secret. REQUIRED in production (no hardcoded fallback).
AUTH_SECRET=your-skillnest-session-secret-min-32-chars
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== HubNest integration (Phase 1) =====
# Must EXACTLY match the JobNest backend SSO_SIGNING_KEY so SkillNest can verify
# the SSO token issued by POST /api/v1/auth/sso/skillnest/.
SSO_SIGNING_KEY=your-dedicated-sso-signing-key-min-50-chars
# JobNest backend base URL (for SSO token exchange + event ingest callbacks).
JOBNEST_API_URL=http://localhost:8000/api/v1
# Optional RS256 hardening: verify SSO tokens against JobNest's JWKS instead of
# the shared SSO_SIGNING_KEY. When set, SSO_SIGNING_KEY is not needed for verify.
JOBNEST_JWKS_URL=http://localhost:8000/api/v1/auth/sso/jwks/
# Shared secret sent as X-Service-Key when SkillNest publishes platform events
# back to JobNest (POST /api/v1/events/ingest/). Must match the backend value.
PLATFORM_EVENT_INGEST_KEY=your-platform-event-ingest-key

# ===== Coding (Judge0) =====
JUDGE0_URL=
JUDGE0_X_AUTH_TOKEN=
REDIS_URL=redis://localhost:6379/3

# ===== Payments (PhonePe) =====
PHONEPE_ENV=sandbox
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1

# ===== AI =====
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ===== Email / SMS =====
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=
DEFAULT_REPLY_TO=
FAST2SMS_API_KEY=
FAST2SMS_SENDER_ID=
FAST2SMS_TEMPLATE_ID=
OTP_EXPIRY_MINUTES=5

# ===== AWS S3 File Storage =====
# Used for all file uploads: images, videos, PDFs, screenshots, assignments
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# Full base URL of your bucket (no trailing slash)
AWS_S3_BUCKET_URL=https://<bucket-name>.s3.<region>.amazonaws.com

# ===== CloudFront CDN (optional) =====
# After creating a CloudFront distribution pointing at the S3 bucket, set this
# to the distribution domain (e.g. https://d1234abcd.cloudfront.net).
# All public URLs will use this domain instead of the direct S3 URL.
# CLOUDFRONT_DOMAIN=https://d1234abcd.cloudfront.net
